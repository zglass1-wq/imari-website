---
// Per-event intro strip: a centered italic statement framed by two gold rules.
// (corporate, newdam) — content via prop, no default.
interface Props { text: string; }
const { text } = Astro.props as Props;
---
<div class="intro-strip">
    <div class="intro-rule"></div>
    <p class="intro-text">{text}</p>
    <div class="intro-rule"></div>
  </div>

<style is:global>
  .intro-strip { background: var(--ink); padding: 4rem 3rem; display: flex; align-items: center; gap: 4rem; justify-content: center; }
  .intro-rule { width: 60px; height: 1px; background: var(--gold); flex-shrink: 0; }
  .intro-text { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.15rem, 2.2vw, 1.55rem); font-weight: 300; font-style: italic; color: rgba(245,240,232,0.8); line-height: 1.55; max-width: 680px; text-align: center; }
  @media (max-width: 900px) {
    .intro-strip { padding: 3.5rem 1.5rem; gap: 0; }
    .intro-rule { display: none; }
  }
</style>
