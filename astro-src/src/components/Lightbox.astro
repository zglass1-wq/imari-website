---
// Lightbox markup only. Behavior is the shared script in PrivatePageLayout.
---
<div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="Photo gallery">
    <span class="lb-label" id="lb-label"></span>
    <span class="lb-counter" id="lb-counter"></span>
    <button class="lb-close" id="lb-close" aria-label="Close">&times;</button>
    <button class="lb-nav lb-prev" id="lb-prev" aria-label="Previous photo">&lsaquo;</button>
    <img class="lb-img" id="lb-img" src="" alt="" />
    <button class="lb-nav lb-next" id="lb-next" aria-label="Next photo">&rsaquo;</button>
  </div>
