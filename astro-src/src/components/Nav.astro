---
// Nav bar + slide-in drawer + backdrop. Scroll-state logic (logo swap,
// .scrolled) lives in the shared script in PrivatePageLayout. Content shared
// by default; drawer links can be made a prop later if a page needs to differ.
const {
  links = [
    { href: '#section-gallery', label: 'Galleries' },
    { href: '#section-weekend', label: 'The Weekend' },
    { href: '#section-estate', label: 'The Estate' },
    { href: '#section-details', label: 'Estate Details' },
    { href: '#section-offering', label: 'The Offering' },
  ],
  planLinks = [{ href: '#section-inquire', label: 'Inquire' }],
  exploreLabel = 'Explore the Weekend',
  planLabel = 'Plan the Stay',
  logoLink = true,
  phone = '+1 (202) 868-6945',
  phoneHref = 'tel:+12028686945',
} = Astro.props;
---
<nav id="site-nav">
    {logoLink ? <a href="/" aria-label="Imari home"><img id="nav-logo" class="nav-logo" src="https://res.cloudinary.com/dsp45h9a1/image/upload/imari-parchment_oactji.svg" alt="Imari" onerror="this.style.display='none'" /></a> : <img id="nav-logo" class="nav-logo" src="https://res.cloudinary.com/dsp45h9a1/image/upload/imari-parchment_oactji.svg" alt="Imari" onerror="this.style.display='none'" />}
    <div class="nav-right">
      <a class="nav-phone" id="nav-phone" href={phoneHref}>{phone}</a>
      <button class="nav-pdf" id="nav-pdf" type="button" aria-label="Download PDF">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="M7 11l5 4 5-4"/><path d="M5 21h14"/></svg>
      </button>
      <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="nav-drawer">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- PDF download progress: fixed pill; labels are the real pipeline stages in
       order, timing estimated (~57s live render, variable). Final label holds
       until the blob arrives. -->
  <div class="pdf-progress" id="pdf-progress" role="status" aria-live="polite" hidden>
    <span class="pdf-progress-dot" aria-hidden="true"></span>
    <span class="pdf-progress-label" id="pdf-progress-label">Unlocking page…</span>
  </div>

  <!-- NAV DRAWER -->
  <div class="drawer-backdrop" id="drawer-backdrop"></div>
  <aside class="drawer" id="nav-drawer" aria-hidden="true" aria-label="Site menu">
    <button class="drawer-close" id="drawer-close" aria-label="Close menu">&times;</button>
    <div class="drawer-inner">
      <p class="section-eyebrow">{exploreLabel}</p>
      <div class="drawer-links">
        {links.map((l: { href: string; label: string }) => <a href={l.href}>{l.label}</a>)}
      </div>
      <div class="drawer-divider"></div>
      <p class="section-eyebrow">{planLabel}</p>
      <div class="drawer-links">
        {planLinks.map((l: { href: string; label: string }) => <a href={l.href}>{l.label}</a>)}
      </div>
    </div>
  </aside>

<style is:global>
  /* Download-PDF icon — matches .nav-phone theming (parchment → warm-mid/gold on scroll). */
  .nav-pdf { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; padding: 0; background: none; border: 0; cursor: pointer; color: var(--parchment); transition: color 0.2s, opacity 0.2s; -webkit-tap-highlight-color: transparent; }
  .nav-pdf:hover { color: var(--gold); }
  .nav-pdf:focus-visible { outline: 1px solid var(--gold); outline-offset: 3px; }
  .nav-pdf:disabled { opacity: 0.45; cursor: progress; }
  nav.scrolled .nav-pdf { color: var(--warm-mid); }
  nav.scrolled .nav-pdf:hover { color: var(--gold); }

  /* Fixed progress pill (decoupled from nav layout so it never reflows the bar). */
  .pdf-progress { position: fixed; left: 50%; bottom: 28px; transform: translateX(-50%); z-index: 1000; display: flex; align-items: center; gap: 10px; max-width: calc(100vw - 32px); padding: 11px 18px; background: rgba(20, 18, 14, 0.92); color: var(--parchment); border: 1px solid rgba(200, 191, 176, 0.18); border-radius: 999px; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; box-shadow: 0 6px 24px rgba(0, 0, 0, 0.35); }
  .pdf-progress[hidden] { display: none; }
  .pdf-progress.is-error { border-color: rgba(184, 146, 46, 0.5); }
  .pdf-progress-label { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .pdf-progress-dot { flex: 0 0 auto; width: 7px; height: 7px; border-radius: 50%; background: var(--gold); }
  @media (prefers-reduced-motion: no-preference) { .pdf-progress-dot { animation: pdfPulse 1s ease infinite; } }
  @keyframes pdfPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById('nav-pdf');
    var pill = document.getElementById('pdf-progress');
    var label = document.getElementById('pdf-progress-label');
    if (!btn || !pill || !label) return;

    // Real pipeline stages, in the order the renderer runs them; timing is
    // estimated (live render measured ~57s, long/variable end). The final
    // label is set last and never superseded — it holds until the blob lands,
    // so an overrun reads as work, never a hang or a premature "done".
    var STAGES = [
      { t: 0,     text: 'Unlocking page…' },     // gate unlock (~2s real) → 4s dwell
      { t: 4000,  text: 'Loading photos…' },     // image loads (heavy)     → 14s dwell
      { t: 18000, text: 'Building galleries…' },  // gallery populate (heaviest) → 20s dwell
      { t: 38000, text: 'Formatting…' },          // layout + print.css (fast) → 6s dwell
      { t: 44000, text: 'Generating PDF…' },      // page.pdf                → 11s dwell
      { t: 55000, text: 'Finishing up…' }         // HOLDS until the blob arrives
    ];
    var timers = [];
    var busy = false;

    function clearTimers() { for (var i = 0; i < timers.length; i++) clearTimeout(timers[i]); timers = []; }

    function startStages() {
      pill.hidden = false;
      pill.classList.remove('is-error');
      STAGES.forEach(function (s) {
        timers.push(setTimeout(function () { label.textContent = s.text; }, s.t));
      });
    }

    function finish() {
      clearTimers();
      pill.hidden = true;
      busy = false;
      btn.disabled = false;
      btn.removeAttribute('aria-busy');
    }

    function fail(msg) {
      clearTimers();
      pill.hidden = false;
      pill.classList.add('is-error');
      label.textContent = msg;
      busy = false;
      btn.disabled = false;
      btn.removeAttribute('aria-busy');
      setTimeout(function () { if (!busy) pill.hidden = true; }, 6000); // auto-dismiss so it never lingers
    }

    // Slug from the URL path: strip query/hash, trailing slashes, leading dirs, and .html/.htm.
    function deriveSlug() {
      var p = (location.pathname || '').split('?')[0].split('#')[0];
      p = p.replace(/\/+$/, '');
      p = p.substring(p.lastIndexOf('/') + 1);
      p = p.replace(/\.html?$/i, '');
      return p;
    }

    btn.addEventListener('click', function () {
      if (busy) return;
      var slug = deriveSlug();
      if (!slug) { fail('Unavailable on this page.'); return; }
      busy = true;
      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');
      startStages();

      fetch('/api/pdf?page=' + encodeURIComponent(slug), { credentials: 'same-origin' })
        .then(function (res) {
          var ct = res.headers.get('content-type') || '';
          if (res.ok && ct.indexOf('application/pdf') !== -1) {
            return res.blob().then(function (blob) {
              if (!blob || (blob.type && blob.type.indexOf('pdf') === -1)) throw { kind: 'render' };
              finish();
              var url = URL.createObjectURL(blob);
              var a = document.createElement('a');
              a.href = url;
              a.download = 'imari-' + slug + '.pdf';
              document.body.appendChild(a);
              a.click();
              a.remove();
              setTimeout(function () { URL.revokeObjectURL(url); }, 5000);
            });
          }
          // Not a PDF: 401/403 = re-gate (auth), anything else = render broke.
          throw { kind: (res.status === 401 || res.status === 403) ? 'auth' : 'render' };
        })
        .catch(function (e) {
          var kind = e && e.kind;
          fail(kind === 'auth'
            ? 'Access expired — reload the page.'
            : 'Couldn’t generate the PDF. Try again.');
        });
    });
  })();
</script>
