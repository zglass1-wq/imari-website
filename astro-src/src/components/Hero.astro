---
// Per-event section — no defaults. All content passed in. Two background
// styles:
//   • bgImage — CSS background-image on .hero (july4 / specific-offering style)
//   • image   — a full-bleed <img class="hero-img"> + .hero-overlay
//               (corporate / newdam style). Hero sizing per page-type comes
//               from the .page--* class on <main> (set via the layout), not here.
// `title` may contain inline HTML (<em>, <br>).
interface Stat { num: string; label: string; }
interface Props {
  title: string;
  paragraph: string;
  stats?: Stat[];
  bgImage?: string;
  image?: string;
  imageAlt?: string;
  eyebrow?: string;
}
const { title, paragraph, stats = [], bgImage, image, imageAlt = 'Imari Georgetown', eyebrow } = Astro.props as Props;
---
<div class="hero" style={bgImage ? `background-image: url('${bgImage}')` : undefined}>{image && <img class="hero-img" src={image} alt={imageAlt} />}{image && <div class="hero-overlay"></div>}
    <div class="hero-content">
      {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}
      <h1 class="hero-title" set:html={title}></h1>
      <p class="hero-sub">{paragraph}</p>
      <div class="hero-stats">
        {stats.map((s) => (
          <div><span class="stat-num">{s.num}</span><span class="stat-label">{s.label}</span></div>
        ))}
      </div>
    </div>
  </div>
