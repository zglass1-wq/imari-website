---
// Slot-based shell for the private pages. Provides <head>, global CSS, Nav,
// <slot/>, Footer, Lightbox, and the one shared script (nav scroll-state,
// drawer, gallery thumbnails, lightbox). A page fills the slot by listing its
// section components in order — there is no section-renderer walking an array.
//
// GALLERIES is injected into the shared script from galleries.ts (the single
// source of gallery data, §5). The script's *logic* is byte-identical to
// july4.html's; only the data is now sourced from galleries.ts instead of
// being inlined.
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';
import { defaultGalleries } from '../data/galleries';
import type { Galleries } from '../data/galleries';

interface NavLink { href: string; label: string; }
interface Props {
  title: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  favicon?: string;
  galleries?: Galleries;
  // Page-type variant → class on <main> (e.g. 'collateral', 'landing'). Drives
  // the per-page CSS overrides for drifted shared selectors. Omitted on the
  // offering baseline (july4v2) so <main id="main-content"> stays unchanged.
  pageVariant?: string;
  // Per-page nav drawer overrides (forwarded to Nav; undefined → Nav defaults).
  navLinks?: NavLink[];
  navPlanLinks?: NavLink[];
  navExploreLabel?: string;
  navPlanLabel?: string;
  navLogoLink?: boolean;
  navPhone?: string;
  navPhoneHref?: string;
  // Per-page footer confidentiality line. Undefined → Footer's shared default
  // ('Confidential · Not for distribution'). Override for pages meant to be
  // forwarded (e.g. a members page shared onward by the recipient).
  footerConf?: string;
}
const {
  title,
  ogTitle,
  ogDescription,
  ogImage = 'https://res.cloudinary.com/dsp45h9a1/image/upload/imari-gingko_bh78d8.svg',
  ogUrl,
  favicon = 'https://res.cloudinary.com/dsp45h9a1/image/upload/imari-gingko_bh78d8.svg',
  galleries = defaultGalleries,
  pageVariant,
  navLinks,
  navPlanLinks,
  navExploreLabel,
  navPlanLabel,
  navLogoLink,
  navPhone,
  navPhoneHref,
  footerConf,
} = Astro.props as Props;

// Self-referential canonical / og:url: prefer the explicit per-page ogUrl prop,
// otherwise derive from the current path against the configured site
// (https://imari.cc). Never points a page at the homepage.
const pageUrl = ogUrl ?? new URL(Astro.url.pathname, Astro.site).href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- Gated, confidential page: keep it out of every search index. -->
  <meta name="robots" content="noindex, nofollow" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={favicon} />
  <link rel="canonical" href={pageUrl} />
  <!-- Social / iMessage preview -->
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
  <style is:inline>
    :root {
      --parchment: #f5f0e8;
      --parchment-dark: #ede6d6;
      --ink: #1a1712;
      --ink-light: #3d3830;
      --gold: #b8975a;
      --gold-light: #d4b07a;
      --warm-mid: #8c7b60;
      --rule: rgba(184,151,90,0.22);
      --rule-dark: rgba(184,151,90,0.45);
      --ember: #1C1A15;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }
    /* Keep anchored sections clear of the fixed nav */
    [id^="section-"] { scroll-margin-top: 90px; }

    body {
      background: var(--parchment);
      color: var(--ink);
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      letter-spacing: 0.01em;
      min-height: 100vh;
    }

    main { opacity: 1; }

    /* NAV — persistent at all widths: logo (left) · phone + hamburger (right) */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 1.5rem 3rem; transition: background 0.3s, padding 0.3s; }
    nav.scrolled { background: rgba(245,240,232,0.97); box-shadow: 0 1px 0 rgba(184,151,90,0.15); padding: 0.6rem 3rem; }
    .nav-logo { width: 88px; transition: opacity 0.3s, width 0.3s; }
    nav.scrolled .nav-logo { width: 56px; }
    .nav-right { display: flex; align-items: center; gap: 1.75rem; }
    .nav-phone { font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--parchment); text-decoration: none; white-space: nowrap; transition: color 0.2s, opacity 0.2s; }
    .nav-phone:hover { opacity: 0.6; }
    nav.scrolled .nav-phone { color: var(--warm-mid); }
    nav.scrolled .nav-phone:hover { color: var(--gold); opacity: 1; }
    .nav-toggle { display: flex; flex-direction: column; justify-content: center; gap: 5px; width: 32px; height: 30px; padding: 4px; background: none; border: 0; cursor: pointer; }
    .nav-toggle span { display: block; width: 24px; height: 1.5px; background: var(--parchment); transition: background 0.3s; }
    nav.scrolled .nav-toggle span { background: var(--warm-mid); }

    /* NAV DRAWER — slides in from the right */
    .drawer-backdrop { position: fixed; inset: 0; z-index: 150; background: rgba(26,23,18,0.45); opacity: 0; visibility: hidden; transition: opacity 0.3s, visibility 0.3s; }
    .drawer-backdrop.open { opacity: 1; visibility: visible; }
    .drawer { position: fixed; top: 0; right: 0; bottom: 0; z-index: 160; width: 360px; max-width: 100%; background: var(--parchment); box-shadow: -16px 0 48px rgba(26,23,18,0.20); transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.4,0,0.2,1); display: flex; flex-direction: column; padding: 1.75rem 2.5rem 2.5rem; overflow-y: auto; }
    .drawer.open { transform: translateX(0); }
    .drawer-close { align-self: flex-end; background: none; border: 0; cursor: pointer; font-size: 1.7rem; line-height: 1; color: var(--warm-mid); padding: 0.25rem 0.1rem; transition: color 0.2s; }
    .drawer-close:hover { color: var(--gold); }
    .drawer-inner { margin-top: 1.25rem; }
    .drawer-inner .section-eyebrow { margin-bottom: 1rem; }
    .drawer-links { display: flex; flex-direction: column; }
    .drawer-links a { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 400; font-size: 1.25rem; line-height: 1.3; color: var(--ink); text-decoration: none; padding: 0.5rem 0; transition: color 0.2s; }
    .drawer-links a:hover { color: var(--gold); }
    .drawer-divider { height: 1px; background: var(--rule); margin: 1.75rem 0; }

    /* HERO */
    .hero { position: relative; height: 100vh; min-height: 600px; overflow: hidden; display: flex; align-items: flex-end; background: var(--ember) center/cover no-repeat; }
    .hero-content { position: relative; padding: 0 3rem 5rem; max-width: 900px; }
    .hero-eyebrow { font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold-light); font-weight: 400; text-shadow: 0 1px 4px rgba(0,0,0,0.9); margin-bottom: 1.5rem; }
    .hero-title { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(2.6rem, 5.4vw, 4.6rem); line-height: 1.08; color: var(--parchment); margin-bottom: 2rem; }
    .hero-title em { font-style: italic; color: var(--gold-light); }
    .hero-sub { font-size: 0.92rem; line-height: 1.85; color: rgba(245,240,232,0.72); max-width: 640px; margin-bottom: 3rem; }
    .hero-stats { display: flex; gap: 4rem; }
    .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 300; color: var(--parchment); display: block; line-height: 1; }
    .stat-label { font-size: 0.58rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,240,232,0.5); margin-top: 0.3rem; display: block; }

    /* SECTION HELPERS */
    .section-eyebrow { font-size: 0.58rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
    .section-title { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.1; color: var(--ink); margin-bottom: 1.25rem; }
    .section-body { font-size: 0.9rem; line-height: 1.9; color: var(--ink-light); }

    /* GALLERY */
    .gallery-section { background: var(--parchment-dark); padding: 7rem 3rem; }
    .gallery-inner { max-width: 1200px; margin: 0 auto; }
    .gallery-header { margin-bottom: 3.5rem; }
    .subgallery { margin-bottom: 3.5rem; }
    .subgallery:last-child { margin-bottom: 0; }
    .subgallery-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding-bottom: 0.75rem; margin-bottom: 0.85rem; border-bottom: 1px solid var(--rule); }
    .subgallery-label { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 400; font-size: 1.5rem; color: var(--ink); }
    .subgallery-viewall { font-size: 0.58rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); text-decoration: none; white-space: nowrap; cursor: pointer; transition: opacity 0.2s; }
    .subgallery-viewall:hover { opacity: 0.6; }
    .thumb-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
    .thumb { aspect-ratio: 4 / 3; overflow: hidden; cursor: pointer; background: var(--parchment-dark); }
    .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s ease, opacity 0.3s; }
    .thumb:hover img { transform: scale(1.04); opacity: 0.9; }

    /* LIGHTBOX */
    .lightbox { position: fixed; inset: 0; z-index: 300; display: none; align-items: center; justify-content: center; background: rgba(26,23,18,0.95); }
    .lightbox.open { display: flex; }
    .lb-img { max-width: 90vw; max-height: 80vh; object-fit: contain; display: block; }
    .lb-label { position: absolute; top: 1.6rem; left: 1.8rem; font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(245,240,232,0.4); }
    .lb-counter { position: absolute; top: 1.5rem; right: 4.2rem; font-size: 0.72rem; letter-spacing: 0.15em; color: rgba(245,240,232,0.6); font-variant-numeric: tabular-nums; }
    .lb-close { position: absolute; top: 1.05rem; right: 1.5rem; background: none; border: 0; cursor: pointer; font-size: 1.9rem; line-height: 1; color: rgba(245,240,232,0.6); transition: color 0.2s; }
    .lb-close:hover { color: rgba(245,240,232,1); }
    .lb-nav { position: absolute; top: 50%; transform: translateY(-50%); background: none; border: 0; cursor: pointer; font-size: 3rem; line-height: 1; color: rgba(245,240,232,0.3); padding: 1rem; transition: color 0.2s; user-select: none; }
    .lb-nav:hover { color: rgba(245,240,232,0.85); }
    .lb-prev { left: 0.5rem; }
    .lb-next { right: 0.5rem; }

    /* POSITIONING */
    .position-wrap { background: var(--ember); padding: 7rem 3rem; }
    .position-inner { max-width: 1360px; margin: 0 auto; }
    .position-statement { max-width: 760px; margin: 0 auto 5rem; text-align: center; }
    .position-statement p:not(.section-eyebrow) { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.5rem, 2.8vw, 2.4rem); font-weight: 300; line-height: 1.45; color: var(--parchment); }
    .position-statement p:not(.section-eyebrow) em { color: var(--gold-light); font-style: italic; }
    .estate-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(200,191,176,0.1); border: 1px solid rgba(200,191,176,0.1); }
    .estate-col { background: var(--ember); padding: 2.75rem 2.25rem; }
    .estate-col-title { font-family: 'Cormorant Garamond', serif; font-size: 1.55rem; font-style: italic; font-weight: 300; color: var(--parchment); margin-bottom: 1.5rem; line-height: 1.2; }
    .estate-list { list-style: none; border-top: 1px solid var(--rule); }
    .estate-list li { font-size: 0.78rem; line-height: 1.7; color: rgba(245,240,232,0.7); padding: 0.7rem 0; border-bottom: 1px solid var(--rule); display: flex; gap: 0.75rem; }
    .estate-list li::before { content: '—'; color: var(--gold); flex-shrink: 0; }

    /* WEEKEND CALENDAR */
    .weekend-section { padding: 7rem 3rem; background: var(--parchment-dark); }
    .weekend-inner { max-width: 1200px; margin: 0 auto; }
    .weekend-head { text-align: center; max-width: 880px; margin: 0 auto 4rem; }
    .weekend-head .section-body { max-width: 780px; margin: 1.5rem auto 0; text-align: left; }
    .weekend-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .day-card { background: var(--parchment); border: 1px solid var(--rule); padding: 0; overflow: hidden; display: flex; flex-direction: column; }
    .day-img { width: 100%; height: 220px; object-fit: cover; display: block; filter: brightness(0.9); }
    .day-body { padding: 2rem 1.8rem 2.4rem; flex: 1; display: flex; flex-direction: column; }
    .day-date { font-size: 0.62rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.8rem; }
    .day-title { font-family: 'Cormorant Garamond', serif; font-size: 1.55rem; color: var(--ink); line-height: 1.2; margin-bottom: 0.8rem; }
    .day-desc { font-size: 0.82rem; line-height: 1.8; color: var(--ink-light); margin-bottom: 1.2rem; }
    .day-meta { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--warm-mid); margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--rule); }

    /* PHOTO BAND */
    .photo-band { display: grid; grid-template-columns: 1.2fr 0.8fr 1fr 0.9fr; height: 340px; overflow: hidden; }
    .photo-band > div { width: 100%; height: 100%; filter: brightness(0.9); transition: filter 0.5s; }
    .photo-band > div:hover { filter: brightness(1.02); }

    /* PROPERTY */
    .property-section { background: var(--ink); padding: 7rem 3rem; overflow: hidden; }
    .property-inner { max-width: 1200px; margin: 0 auto; }
    .property-header { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; margin-bottom: 5rem; align-items: end; }
    .property-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(184,151,90,0.12); border: 1px solid rgba(184,151,90,0.12); margin-bottom: 4px; }
    .prop-col { background: rgba(26,23,18,0.5); padding: 2.5rem; }
    .prop-col-title { font-size: 0.58rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(184,151,90,0.15); }
    .prop-list { list-style: none; }
    .prop-list li { font-size: 0.82rem; line-height: 1.7; color: rgba(245,240,232,0.7); padding: 0.55rem 0; border-bottom: 1px solid rgba(184,151,90,0.08); display: flex; gap: 0.75rem; }
    .prop-list li::before { content: '·'; color: var(--gold); font-size: 1.2rem; line-height: 1.3; flex-shrink: 0; }
    .prop-photos { display: grid; grid-template-columns: 1fr 1fr 1fr; height: 300px; gap: 4px; margin-top: 4px; }
    .prop-photos > div { width: 100%; height: 100%; filter: brightness(0.82) saturate(0.85); transition: filter 0.4s; }
    .prop-photos > div:hover { filter: brightness(0.95) saturate(1); }

    /* POSSIBILITIES */
    .possibilities-section { padding: 7rem 3rem; background: var(--parchment-dark); }
    .possibilities-inner { max-width: 1100px; margin: 0 auto; }
    .possibilities-head { text-align: center; margin-bottom: 3.5rem; }
    .possibilities-cue { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.35rem; color: var(--ink); margin-top: 1rem; }
    .possibilities-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; background: var(--rule); border: 1px solid var(--rule); }
    .pos-item { background: var(--parchment); padding: 1.4rem 1.8rem; border-top: 1px solid var(--rule); border-left: 1px solid var(--rule); display: flex; gap: 1rem; align-items: baseline; font-size: 0.86rem; line-height: 1.7; color: var(--ink-light); }
    .pos-item::before { content: '·'; color: var(--gold); font-size: 1.4rem; line-height: 1; flex-shrink: 0; }

    /* OFFERING */
    .offering-section { padding: 7rem 3rem; background: var(--parchment); }
    .offering-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.2fr; gap: 5rem; align-items: start; }
    .offering-head { position: sticky; top: 5rem; }
    .offering-list { list-style: none; border-top: 1px solid var(--rule); }
    .offering-list li { display: grid; grid-template-columns: 180px 1fr; gap: 2rem; padding: 1.4rem 0; border-bottom: 1px solid var(--rule); align-items: baseline; }
    .offering-key { font-size: 0.62rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); }
    .offering-val { font-size: 0.92rem; line-height: 1.7; color: var(--ink-light); }

    /* CLOSING */
    .closing-section { position: relative; overflow: hidden; min-height: 480px; display: flex; align-items: center; }
    .closing-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 55%; filter: brightness(0.3) saturate(0.65); }
    .closing-content { position: relative; text-align: center; padding: 7rem 2rem; width: 100%; }
    .closing-line { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: clamp(1.5rem, 3vw, 2.4rem); color: var(--parchment); line-height: 1.4; max-width: 820px; margin: 0 auto 2.5rem; }
    .closing-line a { color: var(--gold-light); text-decoration: none; transition: color 0.2s; }
    .closing-line a:hover { color: var(--parchment); }
    .closing-note { font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,240,232,0.32); }

    /* FOOTER */
    footer { background: var(--ink); border-top: 1px solid rgba(184,151,90,0.08); padding: 2rem 3rem; display: flex; align-items: center; justify-content: space-between; }
    .footer-logo { width: 68px; opacity: 0.45; }
    .footer-copy { font-size: 0.58rem; letter-spacing: 0.15em; color: rgba(245,240,232,0.18); text-transform: uppercase; }
    .footer-conf { font-size: 0.58rem; letter-spacing: 0.12em; color: rgba(184,151,90,0.32); text-transform: uppercase; }

    /* Feature-list text (the "—" bullet items) bumped to 0.85rem on
       desktop/laptop only (>=901px), where it was too small on high-density
       screens. Scoped under #main-content so it wins over each component's
       base rule. Mobile (<=900px) is intentionally excluded — it keeps its
       current sizes, so the already-legible mobile layout is unchanged. */
    @media (min-width: 901px) {
      #main-content .estate-list li,
      #main-content .uc-list li,
      #main-content .suite-features li,
      #main-content .tl-items li { font-size: 0.85rem; }
      #main-content .uc-desc { font-size: 0.9rem; }
      #main-content .suites-footnote { font-size: 0.8rem; }
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      nav { padding: 1.1rem 1.5rem; }
      nav.scrolled { padding: 0.85rem 1.5rem; }
      .nav-logo { width: 72px; }
      nav.scrolled .nav-logo { width: 52px; }
      .nav-right { gap: 1.1rem; }
      .drawer { width: 100%; padding: 1.5rem 1.75rem 2.5rem; }
      .hero-content { padding: 0 1.5rem 4rem; }
      .hero-stats { gap: 2rem; flex-wrap: wrap; }
      .gallery-section { padding: 5rem 1.5rem; }
      .gallery-header { margin-bottom: 2.5rem; }
      .subgallery { margin-bottom: 2.5rem; }
      .position-wrap { padding: 5rem 1.5rem; }
      .position-statement { margin: 0 auto 3rem; }
      .estate-grid { grid-template-columns: 1fr; }
      .estate-col { padding: 2rem 1.5rem; }
      .weekend-section { padding: 5rem 1.5rem; }
      .weekend-grid { grid-template-columns: 1fr; gap: 1.25rem; }
      .day-img { height: 200px; }
      .photo-band { grid-template-columns: 1fr 1fr; height: 220px; }
      .photo-band > div:nth-child(3), .photo-band > div:nth-child(4) { display: none; }
      .property-section { padding: 5rem 1.5rem; }
      .property-header { grid-template-columns: 1fr; gap: 2rem; }
      .property-cols { grid-template-columns: 1fr; }
      .prop-photos { grid-template-columns: 1fr 1fr; }
      .prop-photos > div:nth-child(3) { display: none; }
      .possibilities-section { padding: 5rem 1.5rem; }
      .possibilities-grid { grid-template-columns: 1fr; }
      .offering-section { padding: 5rem 1.5rem; }
      .offering-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .offering-head { position: static; }
      .offering-list li { grid-template-columns: 1fr; gap: 0.4rem; }
      footer { flex-direction: column; gap: 1rem; text-align: center; }
    }

    @media (max-width: 640px) {
      .thumb-grid { grid-template-columns: repeat(2, 1fr); }
      .lb-counter { right: 3.6rem; font-size: 0.66rem; }
      .lb-nav { font-size: 2.2rem; padding: 0.5rem; }
      .lb-img { max-width: 94vw; }
    }
  </style>
  <!-- Vercel Web Analytics (enable in Vercel dashboard → Analytics) -->
  <script is:inline>
    window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
  </script>
  <script is:inline defer src="/_vercel/insights/script.js"></script>
</head>
<body>

<main id="main-content" class={pageVariant ? `page--${pageVariant}` : undefined}>

  <Nav links={navLinks} planLinks={navPlanLinks} exploreLabel={navExploreLabel} planLabel={navPlanLabel} logoLink={navLogoLink} phone={navPhone} phoneHref={navPhoneHref} />

  <slot />

  <Footer conf={footerConf} />

  <Lightbox />

</main>

<script define:vars={{ GALLERIES: galleries }}>
  /* ============ NAV: scroll state ============ */
  const nav = document.getElementById('site-nav');
  const navLogo = document.getElementById('nav-logo');
  const LOGO_LIGHT = 'https://res.cloudinary.com/dsp45h9a1/image/upload/imari-parchment_oactji.svg';
  const LOGO_DARK = 'https://res.cloudinary.com/dsp45h9a1/image/upload/imari-gingko_bh78d8.svg';

  window.addEventListener('scroll', () => {
    const heroH = document.querySelector('.hero').offsetHeight;
    const scrolled = window.scrollY > heroH - 80;
    nav.classList.toggle('scrolled', scrolled);
    navLogo.src = scrolled ? LOGO_DARK : LOGO_LIGHT;
  });

  /* ============ NAV DRAWER ============ */
  const navToggle = document.getElementById('nav-toggle');
  const drawer = document.getElementById('nav-drawer');
  const drawerBackdrop = document.getElementById('drawer-backdrop');
  const drawerClose = document.getElementById('drawer-close');

  function openDrawer() {
    drawer.classList.add('open');
    drawerBackdrop.classList.add('open');
    navToggle.setAttribute('aria-expanded', 'true');
    drawer.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    drawer.classList.remove('open');
    drawerBackdrop.classList.remove('open');
    navToggle.setAttribute('aria-expanded', 'false');
    drawer.setAttribute('aria-hidden', 'true');
    if (!isLightboxOpen()) document.body.style.overflow = '';
  }
  navToggle.addEventListener('click', openDrawer);
  drawerClose.addEventListener('click', closeDrawer);
  drawerBackdrop.addEventListener('click', closeDrawer);
  drawer.querySelectorAll('a').forEach(a => a.addEventListener('click', closeDrawer));

  /* ============ THUMBNAILS + VIEW ALL ============ */
  Object.keys(GALLERIES).forEach(key => {
    const g = GALLERIES[key];
    const grid = document.querySelector('.thumb-grid[data-gallery="' + key + '"]');
    if (grid) {
      g.photos.slice(0, 4).forEach((p, i) => {
        const cell = document.createElement('div');
        cell.className = 'thumb';
        const img = document.createElement('img');
        img.src = p.src; img.alt = p.alt || ''; img.loading = 'lazy';
        cell.appendChild(img);
        cell.addEventListener('click', () => openLightbox(key, i));
        grid.appendChild(cell);
      });
    }
    const viewall = document.querySelector('.subgallery-viewall[data-gallery="' + key + '"]');
    if (viewall) {
      viewall.textContent = 'View all ' + g.photos.length + ' →';
      viewall.addEventListener('click', e => { e.preventDefault(); openLightbox(key, 0); });
    }
  });

  /* ============ LIGHTBOX ============ */
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbLabel = document.getElementById('lb-label');
  const lbCounter = document.getElementById('lb-counter');
  let lbPhotos = null, lbIndex = 0, touchX = null;

  function isLightboxOpen() { return lb.classList.contains('open'); }

  function openLightbox(key, idx) {
    const g = GALLERIES[key];
    lbPhotos = g.photos; lbIndex = idx;
    lbLabel.textContent = g.label;
    renderLightbox();
    lb.classList.add('open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function renderLightbox() {
    const p = lbPhotos[lbIndex];
    lbImg.src = p.src; lbImg.alt = p.alt || '';
    lbCounter.textContent = (lbIndex + 1) + ' / ' + lbPhotos.length;
  }
  function stepLightbox(d) {
    if (!lbPhotos) return;
    lbIndex = (lbIndex + d + lbPhotos.length) % lbPhotos.length;
    renderLightbox();
  }
  function closeLightbox() {
    lb.classList.remove('open');
    lb.setAttribute('aria-hidden', 'true');
    lbPhotos = null;
    if (!drawer.classList.contains('open')) document.body.style.overflow = '';
  }

  document.getElementById('lb-close').addEventListener('click', closeLightbox);
  document.getElementById('lb-prev').addEventListener('click', e => { e.stopPropagation(); stepLightbox(-1); });
  document.getElementById('lb-next').addEventListener('click', e => { e.stopPropagation(); stepLightbox(1); });
  lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });

  document.addEventListener('keydown', e => {
    if (isLightboxOpen()) {
      if (e.key === 'Escape') closeLightbox();
      else if (e.key === 'ArrowLeft') stepLightbox(-1);
      else if (e.key === 'ArrowRight') stepLightbox(1);
    } else if (drawer.classList.contains('open') && e.key === 'Escape') {
      closeDrawer();
    }
  });

  lb.addEventListener('touchstart', e => { touchX = e.changedTouches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend', e => {
    if (touchX === null) return;
    const dx = e.changedTouches[0].clientX - touchX;
    if (Math.abs(dx) > 40) stepLightbox(dx < 0 ? 1 : -1);
    touchX = null;
  });
</script>
</body>
</html>
