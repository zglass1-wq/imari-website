---
import PrivatePageLayout from '../layouts/PrivatePageLayout.astro';
import CanonicalStyles from '../components/CanonicalStyles.astro';
import Hero from '../components/Hero.astro';
import IntroStrip from '../components/IntroStrip.astro';
import Gallery from '../components/Gallery.astro';
import UseCase from '../components/UseCase.astro';
import Suites from '../components/Suites.astro';
import InquirySection from '../components/InquirySection.astro';

const CLD = 'https://res.cloudinary.com/dsp45h9a1/image/upload/f_auto,q_auto/';

const navLinks = [
  { href: '#section-gallery', label: 'Galleries' },
  { href: '#section-host', label: 'Host & Entertain' },
  { href: '#section-convene', label: 'Convene & Meet' },
  { href: '#section-stay', label: 'Stay in Town' },
  { href: '#section-service', label: 'The Service' },
  { href: '#section-security', label: 'Privacy & Security' },
  { href: '#section-suites', label: 'Accommodations' },
];
const navPlanLinks = [{ href: '#inquiry', label: 'Inquire' }];

const useCases = [
  {
    id: 'section-host', num: '01', title: 'Host & Entertain', reverse: false,
    image: CLD + 'Living_Room_280_i5lyva.jpg', alt: 'Living room set for entertaining',
    description: 'From an intimate dinner to a 300-guest reception, the estate is a venue built for hosting. Bring your own catering and bar, or hand the evening entirely to our team and Michelin-star kitchen — either way, the property is yours alone for the night.',
    items: [
      'Whole-property exclusivity — no other guests, no lobby, no shared spaces',
      'Up to 60 seated in the 1,000 sq ft ballroom, 24 at a formal dining table, or 300 for a standing reception',
      'Bring your own catering and bar service, or let our Michelin-star chefs and sommeliers handle it',
      'Full event planning and production, from ideation through execution',
      'Parlor, Orangerie, gardens, and ballroom flow from cocktails to dinner without changing venues',
      'Full AV suite for remarks, presentations, and programming',
    ],
  },
  {
    id: 'section-convene', num: '02', title: 'Convene & Meet', reverse: true,
    image: CLD + 'GT_Office_207_lsjhg8.jpg', alt: 'Georgetown office',
    description: "Washington's most consequential conversations happen away from the office. The estate gives you a private, unhurried setting for roundtables, board meetings, and leadership sessions — no competing agenda, no reason to leave until the work is done.",
    items: [
      'Ballroom with customizable layouts for up to 60 seated',
      'Breakout space across stately rooms, gardens, and the grounds',
      'Full AV suite for presentations, panels, and production',
      'Seamless flow from working session to cocktail hour to dinner without changing venues',
      'A private estate makes a statement no hotel ballroom can match',
    ],
  },
  {
    id: 'section-stay', num: '03', title: 'Stay in Town', reverse: false,
    image: CLD + 'Living_Room_331_spepzh.jpg', alt: 'Living room',
    description: 'Rather than scattering your days across hotels and borrowed rooms, make the estate your base in Washington. Six suites and a connected guest house let you and your guests stay, meet, and host without ever changing venues.',
    items: [
      'Six bedroom suites — three king, three queen — plus an attached three-bedroom guest house',
      'Gated arrival court and no public lobby — every arrival controlled and private',
      'One block from the Four Seasons, minutes from the White House and the Capitol',
      'Farm-to-table breakfast, in-residence dining, and a 24/7 concierge',
      'A place to stay, meet, and host on your own terms while you are in town',
    ],
  },
  {
    id: 'section-service', num: '04', title: 'The Service', reverse: true,
    image: CLD + 'Dining_Bar_Cart_126_rtdr2u.jpg', alt: 'Dining room bar cart',
    description: "A full team on property from arrival to departure — concierge, butler, housekeeping, and Michelin-star chefs — anticipating every need so you never have to ask twice.",
    items: [
      '24/7 dedicated concierge managing logistics end-to-end',
      'Butler-led arrival, daily service, and evening turndown',
      'Full housekeeping team and complete property reset after every event',
      'Michelin-star chefs for meals and private dinners; kitchen stocked to your preferences',
      'Farm-sourced breakfast daily, welcome champagne, and floral styling on arrival',
      'Private wellness on request — massage, IV therapy, personal training, spa treatments',
    ],
  },
  {
    id: 'section-security', num: '05', title: 'Privacy & Security', reverse: false,
    image: CLD + 'LXIVDC_GARDENS102_bv6kmk.jpg', alt: 'Estate gardens',
    description: 'Whole-property exclusivity, private arrival, and NDA-bound staff. Vetted and used by heads of state — discretion is the default here, not an upgrade.',
    items: [
      'Complete property exclusivity — no other guests, no shared spaces',
      'Private arrival court — arrivals and departures unseen, no street exposure',
      'Estate-wide security system with perimeter cameras, vetted for heads of state and senior officials',
      'All staff bound by confidentiality agreement before entering the property',
      'Armed security personnel available',
    ],
  },
];

const suiteFloors = [
  { label: 'Second Floor', suites: [
    { name: 'Georgetown Suite', detail: '1100 Sqft · King', features: ['Largest suite in the main house', 'Overlooks the manicured Rose Greely gardens', 'En-suite bath with double vanity', 'Walk-in closet', 'Private office with fireplace'] },
    { name: 'Premier Suite', detail: '750 Sqft · King', features: ['Attached to dedicated meditation/yoga room', 'Spa bath with soaking tub and walk-in shower', 'Private dressing room', 'Motorized blackout shades'] },
    { name: 'Executive Suite', detail: '400 Sqft · King', features: ['Overlooking scenic Olive Street', 'En-suite bath with walk-in shower', 'Fireplace in bedroom'] },
  ] },
  { label: 'Third Floor', suites: [
    { name: 'Garden Suite', detail: '350 Sqft · Queen', features: ['Direct views of the manicured grounds', 'En-suite bath with dual vanity and walk-in shower', 'Quiet placement within the residence'] },
    { name: 'Deluxe Suite 1', detail: '300 Sqft · Queen', features: ['Above the Executive Suite', 'En-suite bath with walk-in shower', 'Gracious proportions and natural light'] },
    { name: 'Deluxe Suite 2', detail: '300 Sqft · Queen', features: ['Bright and intimate with Olive Street facing windows', 'En-suite bath', 'Ideal for single guests or associates'] },
  ] },
];
---
<PrivatePageLayout
  title="Imari · The Executive Branch"
  ogTitle="Imari Georgetown · A Private Estate"
  ogDescription="A fully-staffed private estate in the heart of Georgetown to host, entertain, meet, and stay — reserved for members."
  ogImage={CLD.replace('f_auto,q_auto/', 'f_auto,q_auto,w_1200,h_630,c_fill,g_auto/') + 'Parlor_and_Living_Room_421_ycl671.jpg'}
  ogUrl="https://imari.cc/execbranch.html"
  navLinks={navLinks}
  navPlanLinks={navPlanLinks}
  navExploreLabel="Explore the Estate"
  navPlanLabel="Plan a Visit"
  navLogoLink={false}
  footerConf="Prepared for members of The Executive Branch"
>
  <CanonicalStyles />

  <Hero
    image={CLD + 'Parlor_and_Living_Room_421_ycl671.jpg'}
    imageAlt="Imari Georgetown"
    eyebrow="Prepared for members of The Executive Branch"
    title="A private Georgetown estate,<br><em>reserved for members.</em>"
    paragraph="A walled, fully-staffed estate one block from the Four Seasons — to host, entertain, do business, and stay when you are in Washington. Whole-property exclusivity, Michelin-star culinary, and a full team handling every detail."
    stats={[
      { num: '12,000', label: 'sq.ft.' },
      { num: '1', label: 'Acre of Gardens' },
      { num: '6', label: 'Bedroom Suites' },
      { num: '60', label: 'Seated Capacity' },
      { num: '300', label: 'Event Capacity' },
    ]}
  />

  <IntroStrip text="Washington is where decisions are made. Imari Georgetown is a purpose-built private estate — a block from the Four Seasons, minutes from the White House and the Capitol — where members can convene, entertain, and stay. Whether the evening calls for a seated dinner, a reception, a working session, or simply a private place to land when you're in town, the property is yours alone." />

  <Gallery />

  {useCases.map((uc) => <UseCase {...uc} />)}

  <Suites
    title="The<br>accommodations."
    body="Each suite is distinct and finished to the same exceptional standard. Three king, three queen — across three floors of a 12,000 square foot main house."
    image={CLD + 'GT_Bedroom_222_nrkmzw.jpg'}
    imageAlt="Georgetown Suite"
    floors={suiteFloors}
    footnote="An attached three-bedroom guest house (3 bed · 3 bath · kitchen · living room · office) is available for accompanying staff or guests."
  />

  <InquirySection
    title="Inquire with Blaine Stephens for availability."
    bgImage={CLD + 'LXIVDC_GARDENS157_wtqzaq.jpg'}
    contacts={[
      { label: 'Call', value: '+1 (816) 592-9207', href: 'tel:+18165929207' },
      { label: 'Email', value: 'blaine@imari.cc', href: 'mailto:blaine@imari.cc' },
    ]}
    note="Prepared privately for the members of The Executive Branch."
  />
</PrivatePageLayout>
