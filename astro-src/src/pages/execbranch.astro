---
import PrivatePageLayout from '../layouts/PrivatePageLayout.astro';
import CanonicalStyles from '../components/CanonicalStyles.astro';
import Hero from '../components/Hero.astro';
import IntroStrip from '../components/IntroStrip.astro';
import Gallery from '../components/Gallery.astro';
import UseCase from '../components/UseCase.astro';
import Suites from '../components/Suites.astro';
import InquirySection from '../components/InquirySection.astro';

const CLD = 'https://res.cloudinary.com/dsp45h9a1/image/upload/f_auto,q_auto/';

const navLinks = [
  { href: '#section-gallery', label: 'Galleries' },
  { href: '#section-property', label: 'The Property' },
  { href: '#section-service', label: 'The Service' },
  { href: '#section-host', label: 'Host & Entertain' },
  { href: '#section-security', label: 'Privacy & Security' },
  { href: '#section-extras', label: 'The Extras' },
  { href: '#section-suites', label: 'Accommodations' },
];
const navPlanLinks = [{ href: '#inquiry', label: 'Inquire' }];

const useCases = [
  {
    id: 'section-property', num: '01', title: 'The Property', reverse: false,
    image: CLD + 'LXIVDC_GARDENS134_d5aklw.jpg', alt: 'Estate gardens',
    description: 'A 12,000 sq ft house on a walled, gated acre of gardens in Georgetown. Six suites, a 1,000 sq ft ballroom, a spa house, and a separate guest house for client staff.',
    items: [
      '12,000 sq ft main house on one private acre in Georgetown D.C.',
      'Manicured gardens and greenhouse designed by Rose Greely (1930), updated by Perry Wheeler — designer of the White House Rose Garden',
      'Gated arrival court with parking for 10 vehicles',
      'In the main house: 6 bedroom suites across two floors with 15 bathrooms',
      'Entertainment & living spaces flow naturally across the first floor — Parlor, Living Room, Orangerie, and formal Dining Room',
      "Chef's Kitchen — commercial-grade, built for serious cooking at any scale",
      'Elevator in main residence',
      'Private gym, dedicated yoga/meditation room, full-size swimming pool, and detached Spa House with sauna, steam room, cold plunge, and hot tub',
      'Detached 1,000 sq ft ballroom',
      'Multiple indoor and outdoor spaces for breakouts, receptions, and gatherings',
      'Three-bedroom guest house — separate entrance and self-contained — for client staff (security, EAs, nannies). Available at additional cost.',
    ],
  },
  {
    id: 'section-service', num: '02', title: 'The Service', reverse: true,
    image: CLD + 'Dining_Bar_Cart_126_rtdr2u.jpg', alt: 'Dining room bar cart',
    description: "A full team on property from arrival to departure — concierge, butler, housekeeping, Michelin-star chefs — coordinating everything so the client doesn't have to ask twice.",
    items: [
      '24/7 dedicated concierge managing all logistics end-to-end — planning, reservations, transportation, and on-site coordination',
      'Butler-led arrival, daily service, and evening turndown',
      'Full housekeeping team — daily service and full property reset after events and overnight',
      'In-residence garment care — laundry, pressing, steaming',
      "Property team functions as an extension of the planner's own team",
      'Farm-sourced breakfast daily — fresh fruit, eggs made to order, pastries, organic yogurt, cold-pressed juices, coffee, tea',
      'Stocked kitchen customized in advance to guest preferences',
      'Michelin-star chefs available for meals and private dinners',
      'Welcome champagne, unpacking service, and private guided estate introduction on arrival',
      'Custom floral arrangements styled throughout the estate prior to arrival',
    ],
  },
  {
    id: 'section-host', num: '03', title: 'Host & Entertain', reverse: false,
    image: CLD + 'Living_Room_280_i5lyva.jpg', alt: 'Living room set for entertaining',
    description: 'From an intimate dinner to a 300-guest reception, the estate is a venue built for hosting. Bring your own catering and bar, or hand the evening entirely to our team and Michelin-star kitchen — either way, the property is yours alone for the night.',
    items: [
      'Up to 60 seated in the 1,000 sq ft ballroom, 24 in the formal dining room, or 300+ for a standing reception',
      'Bring your own catering and bar service, or let our Michelin-star chefs and sommeliers handle it',
      'Full event planning and production, from ideation through execution',
      'Parlor, Orangerie, gardens, and ballroom flow from cocktails to dinner without changing venues',
      'Full AV suite for remarks, presentations, and programming',
    ],
  },
  {
    id: 'section-security', num: '04', title: 'Privacy & Security', reverse: true,
    image: CLD + 'LXIVDC_GARDENS102_bv6kmk.jpg', alt: 'Estate gardens',
    description: 'Whole-property exclusivity, private arrival, perimeter cameras, NDA-bound staff. Vetted and used by heads of state — discretion is the default here, not an upgrade.',
    items: [
      'Complete property exclusivity — no other guests, no shared spaces',
      'Private arrival court — arrivals and departures unseen, no street exposure',
      'Estate-wide security system with perimeter cameras, vetted for heads of state and senior officials',
      'All staff bound by confidentiality agreement before entering the property',
      'Armed security personnel available',
    ],
  },
  {
    id: 'section-extras', num: '05', title: 'The Extras', reverse: false,
    image: CLD + 'Spa_House_1058_d3cilj.jpg', alt: 'Estate gardens',
    description: 'Your client asks; we sort it. Wellness, styling, transportation — those are the starting points, not the limits.',
    items: [
      'Central Georgetown — 1 block from the Four Seasons, minutes from the White House and the Capitol',
      'Private wellness programming — massage therapy, acupuncture, IV therapy, yoga instruction, personal training, med-spa treatments',
      'Custom wardrobe and personal styling',
      'Private airport and train transfers included for arrival and departure',
      'Private car and driver available for the duration of the stay',
      'Supercar access and private aviation coordination available on request',
    ],
  },
];

const suiteFloors = [
  { label: 'Second Floor', suites: [
    { name: 'Georgetown Suite', detail: '1100 Sqft · King', features: ['Largest suite in the main house', 'Overlooks the manicured Rose Greely gardens', 'En-suite bath with double vanity', 'Walk-in closet', 'Private office with fireplace'] },
    { name: 'Premier Suite', detail: '750 Sqft · King', features: ['Attached to dedicated meditation/yoga room', 'Spa bath with soaking tub and walk-in shower', 'Private dressing room', 'Motorized blackout shades'] },
    { name: 'Executive Suite', detail: '400 Sqft · King', features: ['Overlooking scenic Olive Street', 'En-suite bath with walk-in shower', 'Fireplace in bedroom'] },
  ] },
  { label: 'Third Floor', suites: [
    { name: 'Garden Suite', detail: '350 Sqft · Queen', features: ['Direct views of the manicured grounds', 'En-suite bath with dual vanity and walk-in shower', 'Quiet placement within the residence'] },
    { name: 'Deluxe Suite 1', detail: '300 Sqft · Queen', features: ['Above the Executive Suite', 'En-suite bath with walk-in shower', 'Gracious proportions and natural light'] },
    { name: 'Deluxe Suite 2', detail: '300 Sqft · Queen', features: ['Bright and intimate with Olive Street facing windows', 'En-suite bath', 'Ideal for single guests or associates'] },
  ] },
  { label: 'Additional Accommodations', suites: [
    { name: 'Guest House', detail: 'Private · Attached', features: ['Attached 3 bedroom guest house', 'Living Room, Kitchen, Office', 'Security Office'] },
  ] },
];
---
<PrivatePageLayout
  title="Imari · The Executive Branch"
  ogTitle="Imari Georgetown · A Private Estate"
  ogDescription="A fully-staffed private estate in the heart of Georgetown where guests can convene, entertain, and stay."
  ogImage={CLD.replace('f_auto,q_auto/', 'f_auto,q_auto,w_1200,h_630,c_fill,g_auto/') + 'Parlor_and_Living_Room_421_ycl671.jpg'}
  ogUrl="https://imari.cc/execbranch.html"
  navLinks={navLinks}
  navPlanLinks={navPlanLinks}
  navExploreLabel="Explore the Estate"
  navPlanLabel="Plan a Visit"
  navLogoLink={false}
  navPhone="amber@imari.cc"
  navPhoneHref="mailto:amber@imari.cc"
  footerConf="Prepared for Executive Branch Members"
>
  <CanonicalStyles />

  <Hero
    image={CLD + 'Parlor_and_Living_Room_421_ycl671.jpg'}
    imageAlt="Imari Georgetown"
    eyebrow="Prepared for Executive Branch Members"
    title="A private estate in Georgetown –<br>fully staffed,<em>entirely yours.</em>"
    paragraph="Imari Georgetown is a private estate, three blocks from the Executive Branch — where guests can convene, entertain, and stay. Whether the evening calls for a seated dinner, a reception, a working session, or simply a private place to land when you're in town, the property is yours alone."
    stats={[
      { num: '12,000', label: 'sq.ft.' },
      { num: '1', label: 'Acre of Gardens' },
      { num: '6', label: 'Bedroom Suites' },
      { num: '60', label: 'Seated Capacity' },
      { num: '300', label: 'Event Capacity' },
    ]}
  />

  <IntroStrip text="Imari Georgetown is a purpose-built private estate for discerning guests. Whole-property exclusivity, complete security, dedicated concierge, Michelin-star culinary, and logistics handled end-to-end – so your experience exceeds expectations." />

  <Gallery keys={['interior', 'exterior', 'site-plan']} />

  {useCases.map((uc) => <UseCase {...uc} />)}

  <Suites
    title="The<br>accommodations."
    body="Each suite is distinct and finished to the same exceptional standard. Three king, three queen — across three floors of a 12,000 square foot main house."
    image={CLD + 'GT_Bedroom_222_nrkmzw.jpg'}
    imageAlt="Georgetown Suite"
    floors={suiteFloors}
    footnote=""
  />

  <InquirySection
    title="Inquire with Amber Chang for availability."
    bgImage={CLD + 'LXIVDC_GARDENS157_wtqzaq.jpg'}
    contacts={[
      { label: 'Call', value: '+1.310.248.0210', href: 'tel:+13102480210' },
      { label: 'Email', value: 'amber@imari.cc', href: 'mailto:amber@imari.cc' },
    ]}
    note="Prepared privately for the members of The Executive Branch."
  />
</PrivatePageLayout>

<style is:global>
  /* Eyebrow legibility: match newdam's larger, tighter treatment instead of the
     0.6rem / 0.3em canonical baseline, which stretches this page's longer
     "PREPARED FOR EXECUTIVE BRANCH MEMBERS" too thin to read over the hero. */
  #main-content .hero-eyebrow { font-size: 0.85rem; letter-spacing: 0.08em; margin-bottom: 1.75rem; }
</style>
