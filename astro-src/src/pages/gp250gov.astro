---
import PrivatePageLayout from '../layouts/PrivatePageLayout.astro';
import Hero from '../components/Hero.astro';
import WeekendSection from '../components/WeekendSection.astro';
import EstateStatement from '../components/EstateStatement.astro';
import Gallery from '../components/Gallery.astro';
import EstateDetails from '../components/EstateDetails.astro';
import OfferingTable from '../components/OfferingTable.astro';
import ClosingInquire from '../components/ClosingInquire.astro';

const heroBg = 'https://res.cloudinary.com/dsp45h9a1/image/upload/f_auto,q_auto/wall-texture_skicra.jpg';
const CLD = 'https://res.cloudinary.com/dsp45h9a1/image/upload/f_auto,q_auto/';

const days = [
  {
    label: 'Friday · August 21',
    title: 'Arrival Dinner and Driver Briefing',
    description:
      'The weekend opens at the estate. A private chef dinner, then a racing briefing from a former driver who has run these streets. Your guests settle in and the conversation starts over the table, before the first engine fires. The night ends at home, on your own terms.',
    image: CLD + 'CleanShot_2026-06-10_at_12.44.04_2x_baxunw.png',
    alt: 'Private chef dinner at the estate',
    meta: '60 people',
  },
  {
    label: 'Saturday · August 22',
    title: 'Qualifying, then the Gala',
    description:
      'Practice and qualifying on the Mall set the grid for Sunday. Back at the estate, a cocktail hour and the unhurried part of the day, where the real talking gets done. When the moment is right, cars take you to the black-tie Pre-Prix 250 gala at the Washington Hilton. Afterward, the car brings you home.',
    image: CLD + 'CleanShot_2026-06-10_at_12.43.23_2x_lrm9bi.png',
    alt: 'Candlelit cocktail setting at Imari',
    meta: '30 people',
  },
  {
    label: 'Sunday · August 23',
    title: 'Race Day on the Mall',
    description:
      'Race day from a private suite at the circuit, the main event live on FOX, the field at full speed against the monuments. When the checkered flag falls, the celebration moves back to the estate and runs as long as the night holds.',
    image: CLD + 'CleanShot_2026-06-10_at_12.43.14_2x_h8cwth.png',
    alt: 'Race day at the circuit',
    meta: '200 people',
  },
];

const offeringRows = [
  { key: 'Dates', value: 'Check in Friday, August 21. Check out Monday, August 24. Three nights.' },
  { key: 'Occupancy', value: 'Nine to eighteen overnight guests. Up to three hundred at evening events.' },
  { key: 'Location', value: 'Central Georgetown. Minutes from the National Mall circuit. Less than two miles from the White House.' },
  { key: 'Included', value: 'Sole-occupancy residence for the stay. Full-service car and driver. Dedicated butler staff. Concierge facilitation of every event on and around the property. Private circuit-suite and gala access coordinated end to end.' },
  { key: 'Pricing', value: '$ 75,000 - $ 150,000 based on planned events and number of guests' },
];
---
<PrivatePageLayout
  title="Imari · Freedom 250 Grand Prix Weekend"
  ogTitle="Freedom 250 Grand Prix Weekend · Imari Georgetown"
  ogDescription="A private setting two miles from the Capitol to make your case, across three days of the first IndyCar street race on the National Mall."
  ogUrl="https://imari.cc/gp250gov.html"
>
  <Hero
    title="The <em>Freedom 250</em><br>Grand Prix weekend"
    paragraph="A private estate, fully staffed, two miles from the Capitol and minutes from the circuit. Three days to deepen the relationships your business depends on, against the backdrop of a once-in-a-generation weekend."
    bgImage={heroBg}
    stats={[
      { num: 'Aug 21-24', label: '3 Nights, sole occupancy' },
      { num: '12,000', label: 'sq.ft.' },
      { num: '18', label: 'Overnight guests' },
      { num: '300', label: 'Event guests' },
    ]}
  />

  <WeekendSection
    title="Room for the conversation to happen."
    paragraph="The Freedom 250 Grand Prix is the first IndyCar street race ever run on the National Mall, the centerpiece of the capital's 250th, and it draws the city's decision-makers to one weekend. A private acre in central Georgetown gives you three days to host them properly and be heard. A private chef dinner and a driver's briefing to open. Qualifying and a black-tie gala through the middle. Race day from a private suite, then a celebration at the estate. Hospitality openly extended, in a setting that earns real attention."
    days={days}
  />

  <EstateStatement />

  <Gallery />

  <EstateDetails />

  <OfferingTable
    body="A single party holds the residence for the entire weekend. The specifics below are the foundation. The guest list and the pace are built around the people you need in the room and the case you are there to make."
    rows={offeringRows}
  />

  <ClosingInquire />
</PrivatePageLayout>
