---
/* ============================================================================
   TEMPLATE · LANDING  (general estate landing page: property / service / venue)
   Source example: newdam.

   HOW TO USE: copy this file to  astro-src/src/pages/<slug>.astro , then edit
   it down and run `npm run build`. Templates live in src/templates/ and are
   NOT built or gated — only pages in src/pages/ are.

   ⚠️ LEFTOVER-CONTENT CHECKLIST — change EVERY item before going live:
     [ ] <PrivatePageLayout>: title, ogTitle, ogDescription, ogImage, ogUrl (→ https://imari.cc/<slug>.html)
     [ ] Nav drawer: navLinks, navPlanLinks, navExploreLabel, navPlanLabel
     [ ] <Hero>: eyebrow, title, paragraph, image, stats[]
     [ ] <IntroStrip>: text
     [ ] <Gallery>: keys (which subgalleries), or pass galleries={...} to override the shared set
     [ ] <UseCase> × N: id, num, title, description, items[], image, alt, reverse (alternate true/false)
     [ ] <Suites>: title, body, image, EVERY floor + suite (name/detail/features[]), footnote
     [ ] <AdvisorStrip>: body
     [ ] <InquirySection>: title + EVERY contact (label/value/href)
     [ ] Gate (CLAUDE.md → "Authoring & launching a private page"): add the vercel.json rewrite,
         middleware.js matcher + ROLE_ALLOWS, api/login.js ROLES, and set IMARI_<SLUG>_PASSWORD in Vercel
   ============================================================================ */
import PrivatePageLayout from '../layouts/PrivatePageLayout.astro';
import CanonicalStyles from '../components/CanonicalStyles.astro';
import Hero from '../components/Hero.astro';
import IntroStrip from '../components/IntroStrip.astro';
import Gallery from '../components/Gallery.astro';
import UseCase from '../components/UseCase.astro';
import Suites from '../components/Suites.astro';
import AdvisorStrip from '../components/AdvisorStrip.astro';
import InquirySection from '../components/InquirySection.astro';

const CLD = 'https://res.cloudinary.com/dsp45h9a1/image/upload/f_auto,q_auto/';

const navLinks = [
  { href: '#section-gallery', label: 'Galleries' },
  { href: '#section-property', label: 'The Property' },
  { href: '#section-service', label: 'The Service' },
  { href: '#section-venue', label: 'The Venue' },
  { href: '#section-security', label: 'The Security' },
  { href: '#section-extras', label: 'The Extras' },
  { href: '#section-suites', label: 'Accommodations' },
];
const navPlanLinks = [
  { href: '#section-advisors', label: 'For Travel Advisors' },
  { href: '#inquiry', label: 'Inquire' },
];

const useCases = [
  {
    id: 'section-property', num: '01', title: 'The Property', reverse: false,
    image: CLD + 'LXIVDC_GARDENS134_d5aklw.jpg', alt: 'Estate gardens',
