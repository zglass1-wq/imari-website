---
<PrivatePageLayout
  title="Imari · Private Info"
  ogTitle="Imari Georgetown · A Private Estate"
  ogDescription="Whole-property exclusivity, full staff, and the comfort of a true home in the heart of Georgetown."
  ogImage={CLD.replace('f_auto,q_auto/', 'f_auto,q_auto,w_1200,h_630,c_fill,g_auto/') + 'Parlor_and_Living_Room_421_ycl671.jpg'}
  ogUrl="https://imari.cc/imaritravel.html"
  navLinks={navLinks}
  navPlanLinks={navPlanLinks}
  navExploreLabel="Explore the Estate"
  navPlanLabel="Plan a Stay"
  navLogoLink={false}
>
  <CanonicalStyles />

  <Hero
    image={CLD + 'Parlor_and_Living_Room_421_ycl671.jpg'}
    imageAlt="Imari Georgetown"
    eyebrow="Imari Georgetown"
    title="A private estate in Georgetown <br>fully staffed, <em>entirely yours.</em>"
    paragraph="Everything a discerning guest expects and more - Whole-property exclusivity, full staff, and the comfort of a true home — so your clients can host, meet, and decompress on their own terms."
    stats={[
      { num: '12,000', label: 'sq.ft.' },
      { num: '1', label: 'Acre of Gardens' },
      { num: '6', label: 'Bedroom Suites' },
      { num: '3', label: 'Staff Bedrooms' },
      { num: '300', label: 'Event Capacity' },
    ]}
  />

  <IntroStrip text="Imari Georgetown is a purpose-built private estate for advisors who need a property that performs. Whole-property exclusivity, dedicated concierge, Michelin-star culinary, and logistics handled end-to-end — so your client's experience exceeds expectations, and so does yours." />

  <Gallery keys={['interior', 'exterior', 'site-plan']} />

  {useCases.map((uc) => <UseCase {...uc} />)}

  <Suites
    title="The<br>accommodations."
    body="Each suite is distinct and finished to the same exceptional standard. Three king, three queen — across three floors of a 12,000 square foot main house."
    image={CLD + 'GT_Bedroom_222_nrkmzw.jpg'}
    imageAlt="Georgetown Suite"
    floors={suiteFloors}
    footnote=""
  />

  <AdvisorStrip body="Commission structure available for qualified trade partners. Dedicated point of contact handles your bookings, your guests, and your client communications end-to-end. Every stay comes with two WhatsApp groups — one with you and your client, one with you and the property team — so your client is always covered and you always know what's happening." />

  <InquirySection
    title="Inquire with Blaine Stephens for availability."
    bgImage={CLD + 'LXIVDC_GARDENS157_wtqzaq.jpg'}
    contacts={[
      { label: 'Call', value: '+1 (202) 868-6945', href: 'tel:+12028686945' },
      { label: 'Email', value: 'blaine@imari.cc', href: 'mailto:blaine@imari.cc' },
    ]}
  />
</PrivatePageLayout>

<style is:global>
  /* imaritravel only: advisor strip in brand Stone (BRAND.md "Stone" #C8BFB0).
     A deliberate distinct section color (NOT the alternation pattern). The
     --stone token isn't in the shared :root, so it's defined here page-scoped
     on #main-content — this keeps it imaritravel-only and leaves the shared/
     canonical AdvisorStrip styling (e.g. newdamv2) untouched. The id selector
     (#section-advisors) outranks the component's .advisor-strip background. */
  #main-content { --stone: #C8BFB0; }
  #section-advisors { background: var(--stone); }
</style>
